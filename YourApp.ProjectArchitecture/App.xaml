<Application x:Class="YourApp.ProjectArchitecture.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:YourApp.ProjectArchitecture"
             xmlns:localView="clr-namespace:YourApp.ProjectArchitecture.Views"
             xmlns:vm="clr-namespace:YourApp.ProjectArchitecture.ViewModels"
             StartupUri="MainWindow.xaml">
    <!-- هذا اللي عليه كومنت تستخدمه فقط وقت الحاجة -->
    <!--StartupUri="MainWindow.xaml"-->
    
    <Application.Resources>

        <!-- Wrap everything in a ResourceDictionary (owner of MergedDictionaries) -->
        <ResourceDictionary>

            <!-- DataTemplate For ContentControl -->
            <!-- الربط النهائي -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <localView:DashboardView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:OrdersViewModel}">
                <localView:OrdersView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <localView:SettingsView/>
            </DataTemplate>
            
            <!-- Here Add Themes in This Resources -->
            <ResourceDictionary.MergedDictionaries>
                <!-- Here Add Themes -->
                <ResourceDictionary Source="/Themes/Buttons.xaml"/>
                <ResourceDictionary Source="/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/Themes/Controls.xaml"/>
                <ResourceDictionary Source="/Themes/Typegraphy.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </Application.Resources>
</Application>
