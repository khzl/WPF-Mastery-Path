<Window x:Class="YourApp.ProjectArchitecture.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YourApp.ProjectArchitecture"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/> <!-- Fixed size -->
            <ColumnDefinition/> <!-- Auto Size -->
        </Grid.ColumnDefinitions>
        
        <!-- Sidebar -->
        <StackPanel Background="#2C3E50">

            <Button Content="Dashboard"
                    Command="{Binding ShowDashboardCommand}"/>

            <Button Content="Orders"
                    Command="{Binding ShowOrdersCommand}"/>

            <Button Content="Settings"
                    Command="{Binding ShowSettingsCommand}"/>
        </StackPanel>
        
        <!-- Content -->
        <ContentControl Grid.Column="1"
                        Content="{Binding NavigationService.CurrentViewModel}"/>
    </Grid>
</Window>
