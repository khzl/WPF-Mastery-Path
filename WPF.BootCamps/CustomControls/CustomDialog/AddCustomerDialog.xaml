<Window x:Class="WPF.BootCamps.CustomControls.CustomDialog.AddCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.CustomControls.CustomDialog"
        mc:Ignorable="d"
        Title="Add Customer" Height="250" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Name:" FontWeight="Bold"/> 
            <TextBox Margin="0,0,0,10"/>
            <TextBlock Text="Email:" FontWeight="Bold"/>
            <TextBox Margin="0,0,0,10"/>
            <Button Content="Save" Width="100"
                    Style="{StaticResource RoundedButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
