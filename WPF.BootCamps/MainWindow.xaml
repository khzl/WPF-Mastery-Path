<Window x:Class="WPF.BootCamps.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps"
        xmlns:vm="clr-namespace:WPF.BootCamps.ViewModels"
        xmlns:views="clr-namespace:WPF.BootCamps.Views.Day_18"
        mc:Ignorable="d"
        Title="WPF BootCamps" Height="450" Width="800">

    <Window.Resources>
        
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:OrdersViewModel}">
            <views:OrdersView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CustomersViewModel}">
            <views:CustomersView/>
        </DataTemplate>
        
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Background="#2C3E50">

            <Button Content="Dashboard"
                Command="{Binding ShowDashboardCommand}"
                Margin="10"/>

            <Button Content="Orders"
                Command="{Binding ShowOrdersCommand}"
                Margin="10"/>

            <Button Content="Customers"
                Command="{Binding ShowCustomersCommand}"
                Margin="10"/>

        </StackPanel>

        <!-- Content -->
        <ContentControl Grid.Column="1"
                    Content="{Binding Navigation.CurrentView}"/>
    </Grid>
</Window>
