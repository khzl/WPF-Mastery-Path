<Window x:Class="WPF.BootCamps.Views.Day_13.commandParameter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.Views.Day_13"
        mc:Ignorable="d"
        Title="commandParameter" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="{Binding SelectedNumber}"
                       FontSize="30"
                       Margin="0,0,0,20"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="1"
                        Command="{Binding SelectNumberCommand}"
                        CommandParameter="1"/>
                <Button Content="2"
                        Command="{Binding SelectNumberCommand}"
                        CommandParameter="2"
                        Margin="5,0"/>
                <Button Content="3"
                        Command="{Binding SelectNumberCommand}"
                        CommandParameter="3"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
