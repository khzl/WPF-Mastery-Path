<Window x:Class="WPF.BootCamps.Views.Day_7.FormUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.Views.Day_7"
        mc:Ignorable="d"
        Title="FormUI" Height="450" Width="800">
    <Grid Width="400"
          HorizontalAlignment="Center"
          VerticalAlignment="Center" Height="196">
        <StackPanel>
            <TextBlock
                Text="Login"
                FontSize="22"
                FontWeight="Bold"
                Margin="0,0,0,16"
                HorizontalAlignment="Center"/>
            <TextBox/>
            <PasswordBox
                Height="32"
                Width="120"
                Margin="0,0,0,20"/>
            <Button
                Content="Sign In"
                Style="{StaticResource ResourceKey=PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
