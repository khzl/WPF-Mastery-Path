<Window x:Class="WPF.BootCamps.Views.Day_9.ButtonControlTemplate"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.Views.Day_9"
        mc:Ignorable="d"
        Title="ButtonControlTemplate" Height="450" Width="800">
    <Grid>
        
        
        <!-- Button Using Control Template -->
        <Button Content="Click Me" Width="150" Height="50" Foreground="White" Margin="122,167,528,217">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        
        <!-- Trigger inside Control Template -->
        <Button Width="150" Height="50" Content="Hover Me" Margin="491,167,159,217">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="SteelBlue"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="DarkBlue"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="Navy"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
        
        <!-- Button ControlTemplate Style -->
        <Button Style="{StaticResource ModernButtonStyle}"
                Content="Save" Margin="308,268,342,116"/>
    </Grid>
</Window>
