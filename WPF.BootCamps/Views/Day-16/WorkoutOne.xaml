<Window x:Class="WPF.BootCamps.Views.Day_16.WorkoutOne"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.Views.Day_16"
        xmlns:localConverter="clr-namespace:WPF.BootCamps.Converters"
        mc:Ignorable="d"
        Title="WorkoutOne" Height="450" Width="800">

    <!-- Register Converter In XAML -->
    <Window.Resources>
        <localConverter:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <localConverter:FullNameConverter x:Key="FullNameConverter"/>
        <localConverter:FullInfoConverter x:Key="FullInfoConverter"/>
    </Window.Resources>
    <Grid>

        <Button Content="Admin Panel"
                Width="120" Height="40" Margin="573,107,107,287"
                Visibility="{Binding IsAdmin,
                             Converter={StaticResource BoolToVisibility}}"/>
        <TextBlock
            Text="Active"
            Visibility="{Binding IsActive,
            Converter={StaticResource BoolToVisibility}}"/>

        <TextBlock Margin="10,33,400,0" VerticalAlignment="Top" Height="36">
            <TextBlock.Text>
                <MultiBinding Converter="{StaticResource FullNameConverter}">
                    <Binding Path="FirstName"/>
                    <Binding Path="LastName"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBox
            Text="{Binding Email,UpdateSourceTrigger=PropertyChanged,ValidatesOnDataErrors=True}" Margin="0,315,0,0" VerticalAlignment="Top"/>

        <TextBlock Margin="10,111,367,0" VerticalAlignment="Top">
            <TextBlock.Text>
                <MultiBinding Converter="{StaticResource FullInfoConverter}">
                    <Binding Path="FirstName"/>
                    <Binding Path="LastName"/>
                    <Binding Path="Age"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

    </Grid>
</Window>
