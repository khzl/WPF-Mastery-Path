<Window x:Class="WPF.BootCamps.Views.Day_6.TestResources"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.Views.Day_6"
        mc:Ignorable="d"
        Title="TestResources" Height="450" Width="800">
    
    <Window.Resources>
        <SolidColorBrush
            x:Key="PrimaryBrush"
            Color="#1976D2"/>
        <SolidColorBrush
            x:Key="BackgroundBrush"
            Color="#245678"/>
        <SolidColorBrush
            x:Key="TextBrush"
            Color="#333333"/>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <TextBlock
            Text="Hello, WPF Resources!"
            Foreground="{StaticResource TextBrush}"
            FontSize="24"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>
        
        <Button
            Content="Save"
            Background="{StaticResource PrimaryBrush}"
            Foreground="White"
            Width="120"
            Height="40"
            FontSize="18"
            FontWeight="Bold" Margin="340,265,340,129"/>
    </Grid>
    
</Window>
