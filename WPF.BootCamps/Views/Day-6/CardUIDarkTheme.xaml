<Window x:Class="WPF.BootCamps.Views.Day_6.CardUIDarkTheme"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.Views.Day_6"
        mc:Ignorable="d"
        Title="CardUIDarkTheme" Height="450" Width="800">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="/Resources/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Border
         Background="{StaticResource SurfaceBrush}"
         Padding="24"
         CornerRadius="8"
         Width="300"
         Margin="42,32,458,246">
            <StackPanel>

            <TextBlock
            Text="Card Title"
            FontSize="18" FontWeight="Bold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Margin="0,0,0,12"/>

            <TextBlock
            Text="This is Description Text..."
            Foreground="{StaticResource TextSecondaryBrush}"
            Margin="0,0,0,16"/>

            <Button
            Content="Action"
            Background="{StaticResource PrimaryBrush}"
            Foreground="White"
            Height="35"
            FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        
        <Border
            Background="{StaticResource SurfaceBrush}"
            Padding="24"
            CornerRadius="8"
            Width="300"
            Margin="444,32,56,246">
            <StackPanel>

                <TextBlock
                    Text="Card Title"
                    FontSize="18" FontWeight="Bold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Margin="0,0,0,12"/>

                <TextBlock
                    Text="This is Description Text..."
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Margin="0,0,0,16"/>

                <Button
                    Content="Action"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    Height="35"
                    FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
    
</Window>
