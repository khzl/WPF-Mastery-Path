<Window x:Class="WPF.BootCamps.Views.Day_8.HierarcyScale"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.Views.Day_8"
        mc:Ignorable="d"
        Title="HierarcyScale" Height="450" Width="800">
    <Grid>
        <StackPanel Width="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="Dasboard"
                       Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="Overview of your Activity"
                       Style="{StaticResource SectionTitleStyle}"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBlock Text="Recent Orders"
                       Style="{StaticResource BodyTextStyle}"/>
        </StackPanel>
    </Grid>
</Window>
