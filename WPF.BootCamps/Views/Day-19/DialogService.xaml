<Window x:Class="WPF.BootCamps.Views.Day_19.DialogService"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.Views.Day_19"
        mc:Ignorable="d"
        Title="DialogService" Height="450" Width="800">
    <Grid>
        <Button Content="Delete"
                Command="{Binding DeleteCommand}"
                Width="120" Height="40"
                Style="{StaticResource RoundedButtonStyle}"/>
        <Button Content="Add Customer"
                Command="{Binding OpenAddCustomerCommand}"
                Width="150" Height="40" Margin="554,196,96,198"
                Style="{StaticResource RoundedButtonStyle}"/>
    </Grid>
</Window>
