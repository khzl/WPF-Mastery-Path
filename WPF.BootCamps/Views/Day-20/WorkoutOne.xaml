<Window x:Class="WPF.BootCamps.Views.Day_20.WorkoutOne"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.BootCamps.Views.Day_20"
        xmlns:converters="clr-namespace:WPF.BootCamps.Converters"
        mc:Ignorable="d"
        Title="WorkoutOne" Height="450" Width="800">
    <Window.Resources>
        <!-- instantiate the converter type with the key used by StaticResource -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid>
        <StackPanel>
            <Button Content="Load Data"
                Command="{Binding LoadCommand}"
                Width="120" Height="40"/>
            <!-- هنا الواجهة تبقى Responsive لان
                  await ما يوقف الـ UI Thread -->
            <TextBlock Text="Loading...."
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,10"/>
            <ItemsControl ItemsSource="{Binding Items}"/>
            <!-- العناصر تظهر وحدة وحدة 
                  الواجهة تبقى حية 
                   تجربة المستخدم تكون افضل -->
            
        </StackPanel>
    </Grid>
</Window>
