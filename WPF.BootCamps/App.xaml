<Application x:Class="WPF.BootCamps.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WPF.BootCamps"
             StartupUri="Views/Day-7/ImplictStyleTest.xaml">
    <!-- StartupUri="MainWindow.xaml" يمكن تغييره إلى نافذة أخرى-->
    <Application.Resources>
        
        <!-- لربط ملفات المصادر الـ Resources نستخدم هاي الطريقة و نربط هنا و نستخدم -->
        <!-- هنا نضيف و نربط كل الـ
        Styles And Colors اللي نعملها كلها نربطها هنا 
        عن طريق هذه الاوامر -->
        
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                
                <ResourceDictionary Source="/Resources/Colors/ColorsTest.xaml"/>
                <!-- باستخدام هذا الامر نربط كل الـ Colors And Styles in App.XAML و نستخدم
                الالوان و الستايلات اللي نعملها بالبرنامج هنا فقط نعرف هذولا ال الالولان و الستايلات داخل هذا الملف خاطر يتعرف عليهم -->
                <ResourceDictionary Source="/Resources/Themes/LightTheme.xaml"/>
                <ResourceDictionary Source="/Styles/SampleStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
        
    </Application.Resources>
</Application>
