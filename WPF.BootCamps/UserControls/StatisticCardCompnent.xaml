<UserControl x:Class="WPF.BootCamps.UserControls.StatisticCardCompnent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF.BootCamps.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
        <Border CornerRadius="10"
                Padding="16"
                Background="White"
                Margin="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding Title , ElementName=root}"
                           FontSize="14"
                           Foreground="Gray"/>
                <TextBlock Text="{Binding Value , ElementName=root}"
                           FontSize="28"
                           FontWeight="Bold"/>
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="📊"
                       FontSize="30"
                       VerticalAlignment="Center"/>
        </Grid>
        </Border> 
</UserControl>
