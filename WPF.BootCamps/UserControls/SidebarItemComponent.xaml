<UserControl x:Class="WPF.BootCamps.UserControls.SidebarItemComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF.BootCamps.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border x:Name="border"
            Padding="10"
            CornerRadius="6"
            Background="Bisque">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding Icon, ElementName=root}"
                       FontSize="16" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding Text, ElementName=root}"
                       FontSize="14"/>
        </StackPanel>
    </Border>
</UserControl>
