<UserControl x:Class="WPF.BootCamps.UserControls.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF.BootCamps.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="250">
    <Border CornerRadius="10"
            Background="White"
            Padding="16"
            Margin="10,10,10,10">
        <StackPanel Margin="0,0,0,-6">
            <!-- Binding Using ElementName Pointing To The UseControl itself -->
            <TextBlock 
                Text="{Binding ProductName , RelativeSource={RelativeSource AncestorType=UserControl}}" 
                FontSize="18" 
                FontWeight="SemiBold"/>
            <TextBlock Text="99.00$"
                       FontSize="14"
                       Margin="0,8,0,0"/>
            <Button Content="Buy"
                    Margin="0,16,0,0"
                    Style="{StaticResource PrimaryButtonStyle}" Height="23" Width="121"/>
        </StackPanel>
    </Border>
</UserControl>
